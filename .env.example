# azure-penny — local development environment
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit it.

# Required: storage account holding Cost Management exports
STORAGE_ACCOUNT_NAME=

# Optional: blob container name (default: cost-exports)
STORAGE_CONTAINER_NAME=cost-exports

# Optional: client ID of the user-assigned managed identity
# Leave empty to use Azure CLI credential (az login) for local dev
AZURE_CLIENT_ID=

# Required for Live Resources tab: Azure subscription ID
AZURE_SUBSCRIPTION_ID=

# Optional: Azure tag key used to identify the application/project (default: project)
# Change to match your tagging convention, e.g. Application, app, workload, system
COST_TAG_KEY=project

# Optional: cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# Optional: live resource cache TTL in seconds (default: 900 = 15 min)
LIVE_CACHE_TTL_SECONDS=900

# Optional: comma-separated resource group names protected from deletion
# Example: rg-prd-penny,rg-prd-shared
PROTECTED_RGS=

# Cloudflare Access — pro volání vertex-proxy (vertex.mysak.fun)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
VERTEX_PROXY_URL=https://vertex.mysak.fun
VERTEX_PROXY_API_KEY=

# Shield — cost alert via Telegram
# Get token from @BotFather, chat_id by messaging the bot then calling getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Monthly budget threshold (EUR/USD). Set to 0 to disable.
SHIELD_MONTHLY_THRESHOLD=0
# Check interval in seconds (default 900 = 15 min)
SHIELD_CHECK_INTERVAL=900
# Cooldown between repeated alerts in seconds (default 7200 = 2 h)
SHIELD_ALERT_COOLDOWN=7200

# Telegram chat (two-way) — webhook config
# Secret token to validate incoming webhook calls from Telegram.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=
# Public HTTPS URL of this app (used to register the webhook at startup).
# In production set by Terraform from custom_domain. For local dev leave empty
# or use ngrok: APP_URL=https://xxxx.ngrok-free.app
APP_URL=
